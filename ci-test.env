# Sample environment for local Azure DevOps CI simulation.
# Usage: env $(cat ci-test.env | grep -v '^#' | xargs) fm <command>
# Or:    export $(grep -v '^#' ci-test.env | xargs) && fm <command>

# --- ADO detection signal ---
TF_BUILD=True

# --- Build metadata ---
BUILD_BUILDID=1042
BUILD_BUILDNUMBER=20260422.1
BUILD_REASON=PullRequest
BUILD_REPOSITORY_NAME=my-repo

# --- PR context (set when BUILD_REASON=PullRequest) ---
SYSTEM_PULLREQUEST_PULLREQUESTID=456
SYSTEM_PULLREQUEST_PULLREQUESTNUMBER=78
SYSTEM_PULLREQUEST_SOURCEBRANCH=refs/heads/feature/73235-my-task
SYSTEM_PULLREQUEST_TARGETBRANCH=refs/heads/main
SYSTEM_PULLREQUEST_SOURCEREPOSITORYURI=https://dev.azure.com/myorg/myproject/_git/my-repo

# --- Organisation context (substitute for fm.toml values) ---
SYSTEM_TEAMFOUNDATIONCOLLECTIONURI=https://dev.azure.com/myorg/
SYSTEM_TEAMPROJECT=myproject

# --- fm credentials (override fm.toml PAT in CI) ---
# FM__PROVIDER__ADO__PAT=your-pat-here
